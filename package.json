{
  "name": "rn-tailwind-tokens",
  "version": "1.0.1",
  "description": "Generate React Native styles from Tailwind + design tokens with Figma sync support",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "rn-tokens": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./react-native": {
      "types": "./dist/react-native.d.ts",
      "import": "./dist/react-native.mjs",
      "require": "./dist/react-native.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react-native",
    "tailwind",
    "design-tokens",
    "figma",
    "styling",
    "css-in-js",
    "stylesheet",
    "tokens",
    "design-system"
  ],
  "author": "Solomon Monotilla",
  "funding": {
    "type": "paypal",
    "url": "https://paypal.me/jobmyt"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fr3em1nd/react-native-tailwind-design-tokens"
  },
  "homepage": "https://github.com/fr3em1nd/react-native-tailwind-design-tokens#readme",
  "bugs": {
    "url": "https://github.com/fr3em1nd/react-native-tailwind-design-tokens/issues"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "deepmerge": "^4.3.1",
    "picocolors": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react-native": "^0.72.8",
    "eslint": "^8.56.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "peerDependencies": {
    "react-native": ">=0.60.0"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    }
  }
}
